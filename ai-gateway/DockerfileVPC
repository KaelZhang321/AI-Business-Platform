ARG BASE_IMAGE=crpi-301jbh81iyvo39lb-vpc.cn-beijing.personal.cr.aliyuncs.com/leczcore_prod/python:3.11.1

FROM ${BASE_IMAGE} AS builder

ARG PIP_INDEX_URL=http://mirrors.cloud.aliyuncs.com/pypi/simple/

ENV PYTHONDONTWRITEBYTECODE=1 \
  PYTHONUNBUFFERED=1 \
  TZ=Asia/Shanghai \
  PIP_INDEX_URL=${PIP_INDEX_URL} \
  PIP_TRUSTED_HOST=mirrors.cloud.aliyuncs.com \
  VIRTUAL_ENV=/opt/venv \
  PATH="/opt/venv/bin:${PATH}" \
  HOME=/opt/model-cache \
  HF_HOME=/opt/model-cache/huggingface \
  TRANSFORMERS_CACHE=/opt/model-cache/huggingface \
  XDG_CACHE_HOME=/opt/model-cache

WORKDIR /app

RUN python -m venv "${VIRTUAL_ENV}" && \
  pip install --upgrade pip setuptools wheel

COPY pyproject.toml ./

# 首先从 pyproject.toml 提取纯粹的第三方包并独立安装（完美利用 Docker 层缓存）
RUN python -c "import tomllib; cfg = tomllib.load(open('pyproject.toml', 'rb')); print('\n'.join(cfg.get('project', {}).get('dependencies', [])))" > /tmp/requirements.txt && \
  pip install --no-cache-dir --progress-bar off -r /tmp/requirements.txt

COPY app ./app

# 此步骤由于大部分沉重第三方包已装完，仅仅是轻量打包当前模块，几乎瞬秒
RUN pip install --no-cache-dir --no-deps .

# 预下载 BGE Embedding + Reranker 模型到缓存目录
#RUN python -c "\
#from FlagEmbedding import BGEM3FlagModel, FlagReranker; \
#BGEM3FlagModel('BAAI/bge-m3', use_fp16=False); \
#FlagReranker('BAAI/bge-reranker-large', use_fp16=False)"

# ── 运行时镜像 ──────────────────────────────────────────
FROM ${BASE_IMAGE} AS runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
  PYTHONUNBUFFERED=1 \
  TZ=Asia/Shanghai \
  VIRTUAL_ENV=/opt/venv \
  PATH="/opt/venv/bin:${PATH}" \
  HOME=/opt/model-cache \
  HF_HOME=/opt/model-cache/huggingface \
  TRANSFORMERS_CACHE=/opt/model-cache/huggingface \
  XDG_CACHE_HOME=/opt/model-cache

WORKDIR /app

# 统一容器时区为 Asia/Shanghai，避免与宿主机日志时间轴错位。
RUN if command -v dnf >/dev/null 2>&1; then \
  dnf install -y tzdata && dnf clean all; \
  elif command -v yum >/dev/null 2>&1; then \
  yum install -y tzdata && yum clean all; \
  else \
  echo "No package manager found for tzdata install" >&2; exit 1; \
  fi && \
  ln -snf /usr/share/zoneinfo/${TZ} /etc/localtime && \
  echo "${TZ}" >/etc/timezone

COPY --from=builder /opt/venv /opt/venv
COPY pyproject.toml ./
COPY app ./app

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
