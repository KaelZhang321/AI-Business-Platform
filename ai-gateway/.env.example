# 服务配置
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# MySQL（注意：使用 mysql+aiomysql 驱动，与 config.py 默认值一致）
DATABASE_URL=mysql+aiomysql://ai_platform:<CHANGE_ME>@localhost:3306/ai_platform?charset=utf8mb4

# Redis
REDIS_URL=redis://:<CHANGE_ME>@localhost:6379/0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=<CHANGE_ME>

# Neo4j
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<CHANGE_ME>

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Text2SQL（火山引擎 ARK / OpenAI 兼容接口）
TEXT2SQL_API_KEY=<CHANGE_ME>
TEXT2SQL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
TEXT2SQL_MODEL=ep-20251108132803-xbb9f

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=<CHANGE_ME>

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=ai_platform_logs

# 外部 LLM API（ModelRouter 备选后端，可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=

# 业务编排层
BUSINESS_SERVER_URL=http://localhost:8080

# LangSmith 可观测性（可选）
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-platform
LANGSMITH_TRACING=false

# RabbitMQ（缓存失效监听）
RABBITMQ_URL=amqp://admin:<CHANGE_ME>@localhost:5672/
