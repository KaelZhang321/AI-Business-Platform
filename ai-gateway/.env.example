# 服务配置
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# AI Gateway MySQL（应用层 docker profile 使用）
BUSINESS_MYSQL_HOST=ai-platform-mysql
BUSINESS_MYSQL_PORT=3306
BUSINESS_MYSQL_USER=ai_platform
BUSINESS_MYSQL_PASSWORD=ai_platform_dev
BUSINESS_MYSQL_DATABASE=ai_platform_gateway

# Health Quadrant - ODS MySQL（套餐/终检意见）
HEALTH_QUADRANT_ODS_MYSQL_HOST=rm-2ze7k76808sos442l.mysql.rds.aliyuncs.com
HEALTH_QUADRANT_ODS_MYSQL_PORT=3306
HEALTH_QUADRANT_ODS_MYSQL_USER=pro_platform
HEALTH_QUADRANT_ODS_MYSQL_PASSWORD=<CHANGE_ME>
HEALTH_QUADRANT_ODS_MYSQL_DATABASE=dc_ods

# Health Quadrant - DW Route（异常拆分接口）
DW_ROUTE_URL=http://127.0.0.1:8085/api/v1
HEALTH_QUADRANT_MYSQL_CONNECT_TIMEOUT_SECONDS=5

# Redis
REDIS_URL=redis://:<CHANGE_ME>@localhost:6379/0

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=<CHANGE_ME>

# Neo4j
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<CHANGE_ME>

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Text2SQL（火山引擎 ARK / OpenAI 兼容接口）
TEXT2SQL_API_KEY=<CHANGE_ME>
TEXT2SQL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
TEXT2SQL_MODEL=ep-20251108132803-xbb9f

# ==================================================
# 火山引擎方舟 (Volcengine Ark) 配置
# ==================================================
# `/api/v1/api-query` 的 Stage-2 / Stage-3 / Stage-5 统一读取这一组配置
ARK_API_KEY=your-ark-api-key
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
ARK_DEFAULT_MODEL=doubao-1-5-pro-32k-250115

# Runtime LLM 配置（service_code -> backend，MySQL 驱动）
LLM_RUNTIME_CONFIG_TABLE=llm_service_backend_config
LLM_RUNTIME_CONFIG_CACHE_TTL_SECONDS=60

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=<CHANGE_ME>

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=ai_platform_logs

# 外部 LLM API（ModelRouter 备选后端，可选）
OPENAI_API_KEY=
OPENAI_BASE_URL=

# 业务编排层
BUSINESS_SERVER_URL=http://localhost:8080
BUSINESS_SERVER_TIMEOUT_SECONDS=15
API_CATALOG_MYSQL_CONNECT_TIMEOUT_SECONDS=5
API_CATALOG_MILVUS_CONNECT_TIMEOUT_SECONDS=5

# 身份金库
IDENTITY_VAULT_ENABLED=true
GATEWAY_JWT_SECRET=

# API Registry / UI Builder metadata
API_CATALOG_SOURCE_MODE=hybrid
UI_BUILDER_METADATA_TIMEOUT_SECONDS=10
UI_BUILDER_METADATA_PAGE_SIZE=100
UI_BUILDER_METADATA_TOKEN=

# LangSmith 可观测性（可选）
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-platform
LANGSMITH_TRACING=false

# RabbitMQ（缓存失效监听）
RABBITMQ_URL=amqp://admin:<CHANGE_ME>@localhost:5672/

# Milvus（补全）
MILVUS_COLLECTION=knowledge_chunks
MILVUS_VECTOR_FIELD=embedding
MILVUS_SEARCH_LIMIT=20

# Elasticsearch（补全）
ELASTICSEARCH_INDEX=knowledge_documents

# GraphRAG 融合权重
RAG_VECTOR_WEIGHT=0.4
RAG_KEYWORD_WEIGHT=0.3
RAG_GRAPH_WEIGHT=0.3
RAG_RERANK_LIMIT=8

# Embedding & Reranker 模型
EMBEDDING_MODEL_NAME=BAAI/bge-m3
# 离线部署时优先读取本地模型目录；建议填写容器内绝对路径
EMBEDDING_MODEL_PATH=
RERANKER_MODEL_NAME=BAAI/bge-reranker-large

# Text2SQL（补全）
TEXT2SQL_DEFAULT_DATABASE=default
TEXT2SQL_TIMEOUT_SECONDS=12
TEXT2SQL_MAX_ROWS=200

# Meeting BI（AI 问数）
MEETING_BI_ENABLED=false
MEETING_BI_DATABASE_URL=mysql+aiomysql://root:<CHANGE_ME>@localhost:3306/meeting_bi?charset=utf8mb4
MEETING_BI_API_KEY=<CHANGE_ME>
MEETING_BI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
MEETING_BI_MODEL=deepseek-v3-2-251201
MEETING_BI_MAX_ROWS=200
MEETING_BI_CONTEXT_TTL_SECONDS=1800
MEETING_BI_TRAIN_ON_STARTUP=false

# 动态 UI
LLM_UI_SPEC_ENABLED=false

# 意图分类
INTENT_CONFIDENCE_THRESHOLD=0.55

# 语义缓存
SEMANTIC_CACHE_ENABLED=false
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.95
SEMANTIC_CACHE_TTL_HOURS=24
SEMANTIC_CACHE_MAX_SIZE=10000
