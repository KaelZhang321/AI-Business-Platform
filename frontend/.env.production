# [线上生产环境配置] - 执行 npm run build:pro (或 npm run build) 时生效
NODE_ENV=production

# 生产环境外网真实域名
VITE_API_BASE_URL="https://ai-platform.ssss818.com/ai-platform"
VITE_BUSINESS_API_URL="https://ai-platform.ssss818.com/ai-platform"

# 线上正式环境使用的 IAM 地址 (如果你们正式服的 IAM 域名不同，请在这里修改，例如去掉 beta-)
VITE_IAM_AUTH_URL="https://beta-crm.ssss818.com/iam/"
VITE_IAM_CLIENT_ID="AI-RND-WORKFLOW"
