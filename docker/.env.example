# MySQL（本地基础设施 docker-compose.yml 使用，共享实例）
MYSQL_ROOT_PASSWORD=ai_platform_dev

# Business Server MySQL（应用层 docker profile 使用）
BUSINESS_MYSQL_HOST=ai-platform-mysql
BUSINESS_MYSQL_PORT=3306
BUSINESS_MYSQL_USER=ai_platform
BUSINESS_MYSQL_PASSWORD=ai_platform_dev
BUSINESS_MYSQL_DATABASE=ai_platform_business

# AI Gateway MySQL（应用层 docker profile 使用）
AI_MYSQL_HOST=ai-platform-mysql
AI_MYSQL_PORT=3306
AI_MYSQL_USER=ai_platform
AI_MYSQL_PASSWORD=ai_platform_dev
AI_MYSQL_DATABASE=ai_platform_gateway

# Redis
REDIS_PASSWORD=redis_dev

# RabbitMQ（云服务，仅保留凭据模板）
RABBITMQ_DEFAULT_USER=admin
RABBITMQ_DEFAULT_PASS=admin_dev

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_dev

# Elasticsearch
ELASTIC_PASSWORD=elastic_dev

# ClickHouse
CLICKHOUSE_PASSWORD=clickhouse_dev

# Neo4j
NEO4J_PASSWORD=neo4j_dev

# Nacos（云服务）
NACOS_AUTH_TOKEN=c2VjcmV0VG9rZW5Gb3JOYWNvc0RldkVudmlyb25tZW50

# ═══════════════════════════════════════════════════════
# AI Gateway 环境变量（覆盖 config.py 默认值）
# ═══════════════════════════════════════════════════════
AI_GATEWAY_HOST_PORT=8000
AI_GATEWAY_IMAGE_TAG=local
APP_ENV=production
APP_DEBUG=false
APP_PORT=8000
# AI Gateway 独立库：ai_platform_gateway
# 数据库连接统一使用上面的 AI_MYSQL_* 变量，由代码内部自动拼装
REDIS_URL=redis://:redis_dev@ai-platform-redis:6379/0
MILVUS_HOST=ai-platform-milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=knowledge_chunks
MILVUS_VECTOR_FIELD=embedding
ELASTICSEARCH_URL=http://ai-platform-elasticsearch:9200
ELASTICSEARCH_PASSWORD=elastic_dev
ELASTICSEARCH_INDEX=knowledge_documents
OLLAMA_BASE_URL=http://ai-platform-ollama:11434
OLLAMA_MODEL=qwen2.5:7b
MINIO_ENDPOINT=ai-platform-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_dev
CLICKHOUSE_URL=http://ai-platform-clickhouse:8123
CLICKHOUSE_DB=ai_platform_logs
CLICKHOUSE_RAG_TABLE=rag_metrics
NEO4J_URI=neo4j://ai-platform-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_dev
EMBEDDING_MODEL_NAME=BAAI/bge-m3
RERANKER_MODEL_NAME=BAAI/bge-reranker-large
BUSINESS_SERVER_URL=http://ai-platform-business-server:8080
RABBITMQ_URL=amqp://admin:admin_dev@ai-platform-rabbitmq:5672/
OPENAI_API_KEY=
OPENAI_BASE_URL=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-platform
LANGSMITH_TRACING=false

# ═══════════════════════════════════════════════════════
# Business Server 环境变量
# ═══════════════════════════════════════════════════════
# Business Server 独立库：ai_platform_business
BUSINESS_SERVER_HOST_PORT=8080
BUSINESS_SERVER_IMAGE_TAG=local
